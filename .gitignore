# ... existing ignores ...
__pycache__/
*.pyc
# Rolling app logs (hub.log + rotated hub.log.N)
inventory-hub/hub.log*
# Claude local settings + runtime locks
.claude/settings.local.json
.claude/*.lock

# Secrets & Local Config
config.json
.env
config.dev.json
config.prod.json
inventory-hub/out.json
hub.log
.config_mtime

# Runtime state — NEVER track these. Committed versions will clobber
# a live install's real data on every `git pull`. All runtime state
# now lives under inventory-hub/data/. We broadly gitignore the whole
# subtree and explicitly track only documentation + seed files.
inventory-hub/data/*
!inventory-hub/data/README.md
!inventory-hub/data/locations.json.example
# Belt-and-suspenders: legacy paths + backup files from any migration.
inventory-hub/locations.json
inventory-hub/locations.json.*.bak
inventory-hub/data/locations.json.*.bak
