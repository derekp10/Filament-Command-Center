{
    "comment": "--- GLOBAL CONFIGURATION ---",
    "server_ip": "192.168.1.100",
    "SCRAPER_API_KEY": "",
    "spoolman_port": 7912,
    "sync_delay": 0.5,
    
    "comment_paths": "--- PATHS & BACKUPS ---",
    "comment_note": "For Docker, use container paths (e.g., /app/data/). For Windows, use full paths (e.g., D:\\Backups)",
    "spoolman_db_path": "\\\\NAS\\Path\\To\\spoolman.db",
    "backup_directory": "./backups",
    "export_directory": "./exports",

    "comment_print": "--- LABEL PRINTING (browser or csv) ---",
    "print_settings": {
        "mode": "browser",
        "csv_path": "./labels/print_queue.csv"
    },
    "buy_more_url_template": "https://www.amazon.com/s?k={{vendor}}+{{color}}+{{material}}",
    
    "comment_maps": "--- INVENTORY HUB SETTINGS ---",
    "printer_map": {
        "PRINTER_1": {"printer_name": "My Printer", "position": 0}
    },
    "comment_bindings": "Dryer-box-to-toolhead bindings are stored per-slot on each Dryer Box location in locations.json under extra.slot_targets — edit via Location Manager UI.",
    "dryer_slots": [],

    "comment_pathfil": "--- MID-PRINT SWAP DEDUCT (22.3b): grams between the runout sensor and the nozzle, pulled out (never printed) when you swap a run-out spool. Added to the run-out spool's auto-deduct so its weight matches the empty spool. 0 = off. EDIT THIS IN THE CONFIG TOOL (Behavior section), not here. Typical ~2 (Core One) / ~4 (XL); one value covers all printers for now. Advanced: a {printer_name: grams} map is also honored by the reader for a future per-printer version.",
    "path_filament_g": 0
}