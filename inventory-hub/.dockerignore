# Keep tests and dev artifacts OUT of the production image.
# Build context is inventory-hub/; everything here is relative to that.

# Test harness
tests/
conftest.py
pytest.ini
.pytest_cache/
__screenshots__/

# Stray test files at the inventory-hub root
test_*.py

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log
*.log.*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Backups
*_BACKUP.csv
*.bak

# Runtime state — belongs on the mounted volume, not in the image.
# Fresh images come up empty; the CSV-to-JSON migration seeds
# data/locations.json on first run if a legacy CSV is present.
data/*
!data/README.md
!data/locations.json.example

# Docs / dev scripts that don't need to ship
debug_*.py
